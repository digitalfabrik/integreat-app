{
  "name": "build-configs",
  "version": "0.0.1",
  "description": "Build configs for the Integreat project",
  "private": true,
  "type": "module",
  "dependencies": {
    "translations": "0.0.1"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./aschaffenburg/build-config-name": {
      "import": "./src/integreat/build-config-name/index.ts",
      "types": "./src/integreat/build-config-name/index.d.ts",
      "default": "./src/integreat/build-config-name/index.ts"
    },
    "./integreat/build-config-name": {
      "import": "./src/integreat-test-cms/index.js",
      "types": "./src/integreat-test-cms/index.d.ts",
      "default": "./src/integreat-test-cms/index.js"
    },
    "./integreat-test-cms": {
      "import": "./src/integreat-test-cms/index.ts",
      "types": "./src/integreat-test-cms/index.d.ts",
      "default": "./src/integreat-test-cms/index.ts"
    },
    "./integreat-test-cms/build-config-name": {
      "import": "./src/integreat-test-cms/build-config-name/index.ts",
      "types": "./src/integreat-test-cms/build-config-name/index.d.ts",
      "default": "./src/integreat-test-cms/build-config-name/index.ts"
    },
    "./obdach/build-config-name": {
      "import": "./src/obdach/build-config-name/index.ts",
      "types": "./src/obdach/build-config-name/index.d.ts",
      "default": "./src/obdach/build-config-name/index.ts"
    },
    "./obdach": {
      "import": "./src/obdach/index.ts",
      "types": "./src/obdach/index.d.ts",
      "default": "./src/obdach/index.ts"
    },
    "./*.svg": {
      "import": "./src/*.svg",
      "types": "./src/*.svg",
      "default": "./src/*.svg"
    },
    "./*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "devDependencies": {
    "@types/flat": "^5.0.5",
    "csstype": "^3.2.3",
    "decamelize": "^5.0.1",
    "flat": "^5.0.2"
  },
  "scripts": {
    "ts:check": "tsc --build",
    "lint": "eslint --cache --cache-location ../.eslintcache .",
    "check-circular-dependencies": "yarn run -T check-circular-dependencies"
  }
}
