{
  "name": "build-configs",
  "version": "0.0.1",
  "main": "index.ts",
  "description": "Build configs for the integreat project",
  "private": true,
  "type": "module",
  "dependencies": {
    "translations": "0.0.1"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./obdach": {
      "import": "./dist/obdach/index.js",
      "default": "./dist/obdach/index.js",
      "types": "./dist/obdach/index.d.ts"
    },
    "./integreat-test-cms": {
      "import": "./dist/integreat-test-cms/index.js",
      "default": "./dist/integreat-test-cms/index.js",
      "types": "./dist/integreat-test-cms/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "devDependencies": {
    "@types/flat": "^5.0.5",
    "csstype": "^3.2.3",
    "decamelize": "^5.0.1",
    "flat": "^5.0.2"
  },
  "scripts": {
    "ts:check": "tsc --build",
    "lint": "eslint --cache --cache-location ../.eslintcache .",
    "check-circular-dependencies": "yarn run -T check-circular-dependencies"
  }
}
