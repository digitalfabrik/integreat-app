{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES5", "ES6", "dom"],
    // Fixes "Static class blocks are not enabled. Please add `@babel/plugin-transform-class-static-block` to your configuration"
    "target": "ES2021",
    "types": ["jest", "node"],
    "typeRoots": ["./src/@types", "node_modules/@types", "../node_modules/@types"]
  },
  "include": ["jest.config.ts", "jest.setup.ts", "src"]
}
