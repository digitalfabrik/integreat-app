{
  "name": "shared",
  "version": "0.0.1",
  "description": "Code shared between native and web mostly for api",
  "sideEffects": false,
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:changed": "yarn run test -o",
    "test:watch": "yarn run test --watchAll",
    "check-circular-dependencies": "yarn run -T check-circular-dependencies",
    "lint": "eslint --cache --cache-location ../.eslintcache .",
    "ts:check": "tsc --build"
  },
  "exports": {
    "./api": {
      "import": "./src/api/index.ts",
      "types": "./src/api/index.d.ts",
      "default": "./src/api/index.ts"
    },
    "./api/*": {
      "import": "./src/api/*.ts",
      "types": "./src/api/*.d.ts",
      "default": "./src/api/*.ts"
    },
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "react": "19.2.3"
  },
  "dependencies": {
    "@turf/distance": "^7.3.4",
    "deepmerge-ts": "^7.1.5",
    "entities": "^7.0.1",
    "highlight-words-core": "^1.2.3",
    "htmlparser2": "^10.1.0",
    "luxon": "^3.7.2",
    "minisearch": "^7.2.0",
    "normalize-path": "^3.0.0",
    "qr": "^0.6.0",
    "rrule": "2.8.1",
    "sanitize-html": "^2.17.5",
    "sentencex": "^0.4.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/normalize-path": "^3.0.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/seedrandom": "^3.0.8",
    "@types/uuid": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "js-sha256": "^0.11.1",
    "react": "19.2.3",
    "seedrandom": "^3.0.5"
  }
}
