{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",

    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // We only build JS with vite, not tsc
    "noEmit": true,

    "types": ["jest", "@testing-library/jest-dom", "node", "react", "vite/client"]
  },
  "include": ["src/**/*", "src/**/*.json"],
  "references": [
    {
      "path": "../translations"
    },
    {
      "path": "../build-configs"
    },
    {
      "path": "../shared"
    }
  ]
}
