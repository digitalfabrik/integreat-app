{
  "compilerOptions": {
    "composite": true,
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": false, // leads to oom when linting
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ESNext",
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "outDir": "dist",
    "types": ["jest"]
  },
  "include": ["jest.config.ts", ".prettierrc",
    "eslint.config.js"
  ],
  "references": [
    { "path": "shared" },
    { "path": "build-configs" },
    { "path": "e2e-tests" },
    { "path": "native" },
    { "path": "translations" },
    { "path": "web" }
  ]
}
