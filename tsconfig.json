{
  // This configuration is only used to type check all TS packages in the repo.

  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "forceConsistentCasingInFileNames": false, // leads to oom when linting
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "useDefineForClassFields": false,
    "noEmit": true,
    "types": ["jest"]
  },
  "references": [
    { "path": "build-configs" },
    { "path": "e2e-tests" },
    { "path": "native" },
    { "path": "shared" },
    { "path": "translations" },
    { "path": "web" }
  ]
}
