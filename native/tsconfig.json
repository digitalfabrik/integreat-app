{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": true, // We only build JS with metro, not tsc; tsc emits only declarations (required for project references)
    "paths": {
      "normalize-strings": ["../shared/@types/normalize-strings"],
      "@dr.pogodin/react-native-static-server": ["./src/@types/react-native-static-server"],
      "@react-native-async-storage/async-storage/jest/async-storage-mock": ["./src/@types/untyped"]
    },
    "typeRoots": ["./src/@types", "./node_modules/@types", "../node_modules/@types"],
    "types": ["jest", "node"]
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["metro.config.js", "metro.config.ci.js"],
  "references": [
    {
      "path": "../translations"
    },
    {
      "path": "../build-configs"
    },
    {
      "path": "../shared"
    }
  ]
}
