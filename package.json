{
  "name": "integreat-app",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "native",
    "web",
    "e2e-tests",
    "shared",
    "translations",
    "build-configs"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint --cache --cache-location .eslintcache . && yarn workspace web stylelint && yarn workspace native stylelint",
    "lint:ci": "yarn node --max-old-space-size=2048 $(yarn bin eslint) --format junit -o reports/lint/junit-lint.xml .",
    "test": "jest",
    "test:changed": "jest -o",
    "test:ci": "jest --coverage --ci",
    "circleci:update-config": "{ cat .circleci/autogenerated_header.yml; circleci config pack .circleci/src; } > .circleci/config.yml && circleci config validate",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "ts:check": "tsc --build",
    "ts:check:ci": "yarn node --max-old-space-size=1536 $(yarn bin tsc) --build",
    "postinstall": "yarn workspace native postinstall && yarn workspace web postinstall"
  },
  "resolutions": {
    "luxon": "3.7.2",
    "react": "19.1.1",
    "@types/react": "19.1.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.0",
    "@types/react": "19.1.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "app-toolbelt": "github:digitalfabrik/app-toolbelt#semver:0.9.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-junit": "^9.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-styled-components-a11y": "^2.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "minimatch": "^10.2.4",
    "postcss": "^8.5.8",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-react-native-styled-components": "^0.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-react-native": "^2.7.0",
    "stylelint-use-logical": "^2.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
